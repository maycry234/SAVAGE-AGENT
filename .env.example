# === Required ===
HELIUS_API_KEY=your_helius_api_key
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# === Trading Wallet ===
ENCRYPTION_KEY=your_fernet_encryption_key
TRADER_WALLET_KEY=your_encrypted_wallet_private_key

# === Optional: Grok/xAI for CT Motion ===
GROK_API_KEY=your_grok_api_key
GROK_MODEL=grok-3-mini

# === Optional: Override Defaults ===
# HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=
# JUPITER_API_URL=https://api.jup.ag/swap/v1
# DEXSCREENER_API_URL=https://api.dexscreener.com/latest
# WALLET_POLL_INTERVAL=10
# CONVERGENCE_WINDOW=120
# MIN_APES=2
# BUY_SCORE_THRESHOLD=60
# MAX_POSITION_SOL=10.0
# SLIPPAGE_BPS=1500
# MAX_CONCURRENT_POSITIONS=3
# LOG_LEVEL=INFO
